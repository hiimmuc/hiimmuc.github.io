---
layout: none
permalink: /images/icons/manifest.json
---
{
    "name": {{ site.title | jsonify }},
    "short_name": {{ site.name | jsonify }},
    "description": {{ site.description | jsonify }},
    "start_url": "{{ site.baseurl | default: '/' }}",
    "lang": {{ site.locale | default: "en" | jsonify }},
    "icons": [
        {
            "src": "/images/icons/favicon-192x192.webp",
            "sizes": "192x192",
            "type": "image/png"
        },
        {
            "src": "/images/icons/favicon-512x512.webp",
		}
	]
}
